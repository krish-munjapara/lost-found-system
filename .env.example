# Guardian-Link — Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.

# ── Required ──
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=guardian-link
SECRET_KEY=generate-a-long-random-string-at-least-32-chars

# ── Application ──
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:5173
DB_NAME=guardian_link
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT ──
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin (change before first production deploy) ──
DEFAULT_ADMIN_EMAIL=admin@guardianlink.com
DEFAULT_ADMIN_PASSWORD=change-me-after-first-login
DEFAULT_ADMIN_NAME=System Admin

# ── Uploads ──
MAX_UPLOAD_SIZE_MB=10
MATCH_THRESHOLD=50
TOP_MATCH_LIMIT=5

# ── AI Face Matching ──
# Change this to another supported DeepFace model name if needed, e.g. ArcFace, Facenet, GhostFaceNet
FACE_MODEL_NAME=ArcFace

# ── Cloudinary (optional — local storage used if empty) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email / SMTP (optional — console mode if empty) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@guardianlink.com

# ── Legacy Flask scripts only ──
LEGACY_DB_NAME=lostfound
