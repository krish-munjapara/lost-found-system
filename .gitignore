# ──────────────────────────────────────────────
# Guardian-Link .gitignore
# ──────────────────────────────────────────────

# Dependencies
node_modules/
frontend/node_modules/

# Build output
dist/
build/
frontend/dist/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/

# Virtual environments
venv/
.env/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.production

# Uploads (generated content)
backend/uploads/lost/*
backend/uploads/found/*
!backend/uploads/lost/.gitkeep
!backend/uploads/found/.gitkeep

# AI Model weights (too large for git)
ai-model/*.h5
ai-model/*.pt
ai-model/*.pb
~/.deepface/

# Logs
*.log
npm-debug.log*

# Coverage
coverage/
.nyc_output/

# Misc
*.bak
*.tmp

# Old Flask files (deprecated)
static/
templates/
