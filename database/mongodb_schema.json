{
  "database": "guardian_link",
  "collections": {
    "users": {
      "description": "Stores registered user accounts (admins, users, authorities)",
      "schema": {
        "_id": "ObjectId (auto-generated)",
        "full_name": "String — User's full name",
        "email": "String — Unique email address (indexed)",
        "password": "String — Bcrypt hashed password",
        "mobile": "String — Mobile phone number",
        "gender": "String — Male / Female / Other",
        "address": "String — User's address",
        "role": "String — User / Admin / Authority",
        "created_at": "DateTime — Account creation timestamp"
      },
      "indexes": [
        { "field": "email", "unique": true }
      ]
    },

    "children": {
      "description": "Stores missing children reports with face encodings",
      "schema": {
        "_id": "ObjectId (auto-generated)",
        "name": "String — Child's name",
        "age": "String — Age or age range",
        "gender": "String — Male / Female / Other",
        "location": "String — Last seen location",
        "description": "String — Physical description, clothing, marks",
        "image": "String — Filename in uploads/lost/ directory",
        "encoding": "String (JSON) — Facenet face embedding vector",
        "status": "String — Pending / Ai Matches / Resolved",
        "created_at": "DateTime — Report timestamp"
      },
      "indexes": [
        { "field": "status" },
        { "field": "created_at" }
      ]
    },

    "children_found": {
      "description": "Stores found children reports with face encodings",
      "schema": {
        "_id": "ObjectId (auto-generated)",
        "name": "String — Name (if known) or 'Unknown'",
        "age": "String — Approximate age",
        "gender": "String — Male / Female / Other",
        "location": "String — Found location",
        "description": "String — Condition, clothing, spoken language",
        "image": "String — Filename in uploads/found/ directory",
        "encoding": "String (JSON) — Facenet face embedding vector",
        "created_at": "DateTime — Report timestamp"
      },
      "indexes": [
        { "field": "created_at" }
      ]
    },

    "matches": {
      "description": "Stores AI-computed face similarity matches",
      "schema": {
        "_id": "ObjectId (auto-generated)",
        "missing_id": "ObjectId — Reference to children collection",
        "found_id": "ObjectId — Reference to children_found collection",
        "score": "Number — Similarity percentage (0-100)",
        "created_at": "DateTime — Match computation timestamp"
      },
      "indexes": [
        { "field": "score" },
        { "field": "missing_id" },
        { "field": "found_id" }
      ]
    },

    "notifications": {
      "description": "Stores system notifications and alerts",
      "schema": {
        "_id": "ObjectId (auto-generated)",
        "message": "String — Notification text",
        "created_at": "DateTime — Notification timestamp",
        "read": "Boolean — Whether the notification has been read"
      },
      "indexes": [
        { "field": "created_at" }
      ]
    }
  },

  "notes": {
    "image_storage": "Images are stored as file paths (filenames) pointing to uploads/lost/ and uploads/found/ directories, NOT as binary data in MongoDB.",
    "face_encodings": "Face embeddings are stored as JSON-serialized arrays of 128 or 512 floats (depending on the model). They are computed using DeepFace with the Facenet model.",
    "matching_logic": "When a new report is submitted (missing or found), the system automatically computes cosine similarity against all existing records of the opposite type. Matches above 50% threshold are saved."
  }
}
